generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
  GUARDIAN
}

enum QuizStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  LOGIN_VERIFICATION
  PASSWORD_RESET
}

enum StaffInvitationStatus {
  INVITED
  SUBMITTED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum StudentAdmissionStatus {
  REQUESTED
  INVITED
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  role         UserRole
  name         String
  email        String   @unique
  passwordHash String?
  phoneNumber  String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  otpCodes           OtpCode[]
  passwordResetTokens PasswordResetToken[]
  sectionCourseAssignments SectionCourseAssignment[]
}

model OtpCode {
  id           String     @id @default(cuid())
  userId       String
  purpose      OtpPurpose
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model StaffInvitation {
  id               String                @id @default(cuid())
  email            String                @unique
  name             String
  role             UserRole
  tokenHash        String                @unique
  status           StaffInvitationStatus @default(INVITED)
  phoneNumber      String?
  educationDetails String?
  personalDetails  String?
  documentLinks    Json?
  adminNotes       String?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  expiresAt        DateTime
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([status, createdAt])
}

model AcademicClass {
  id           String         @id @default(cuid())
  name         String
  code         String         @unique
  academicYear String
  description  String?
  isActive     Boolean        @default(true)
  sections     ClassSection[]
  admissionRequests StudentAdmission[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([academicYear, isActive])
}

model ClassSection {
  id             String        @id @default(cuid())
  classId        String
  name           String
  capacity       Int           @default(30)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  academicClass  AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  courseAssignments SectionCourseAssignment[]
  admittedStudents StudentAdmission[]

  @@unique([classId, name])
  @@index([classId, isActive])
}

model StudentAdmission {
  id               String                 @id @default(cuid())
  name             String
  email            String                 @unique
  desiredClassId   String
  assignedSectionId String?
  selectedCourseIds Json
  status           StudentAdmissionStatus @default(REQUESTED)
  tokenHash        String?                @unique
  phoneNumber      String?
  personalDetails  Json?
  guardianDetails  Json?
  educationDetails Json?
  documentLinks    Json?
  adminNotes       String?
  expiresAt        DateTime?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  desiredClass     AcademicClass          @relation(fields: [desiredClassId], references: [id], onDelete: Restrict)
  assignedSection  ClassSection?          @relation(fields: [assignedSectionId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([desiredClassId, assignedSectionId])
}

model SectionCourseAssignment {
  id        String        @id @default(cuid())
  sectionId String
  courseId  String
  teacherId String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  section   ClassSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher   User          @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@unique([sectionId, courseId])
  @@index([teacherId, isActive])
}

model Course {
  id          String   @id @default(cuid())
  code        String?  @unique
  title       String
  description String?
  level       String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sectionAssignments SectionCourseAssignment[]
}

model Lecture {
  id          String   @id @default(cuid())
  courseId    String
  videoUrl    String
  transcript  String?
  title       String
  lectureOrder Int     @default(0)
  durationMinutes Int?
  videoProvider String?
  isCheckpointLocked Boolean @default(true)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Checkpoint {
  id            String   @id @default(cuid())
  lectureId     String
  title         String   @default("Checkpoint")
  timestamp     Int
  requiredQuizId String?
  sortOrder     Int      @default(0)
  unlockScore   Int      @default(70)
  isBlocking    Boolean  @default(true)
  isPublished   Boolean  @default(false)
}

model QuizQuestion {
  id            String     @id @default(cuid())
  lectureId     String?
  sourceTopic   String?
  sourceTranscript String?
  question      String
  options       Json
  correctAnswer String
  difficulty    String
  topic         String?
  questionType  String     @default("mcq")
  answerExplanation String?
  attemptLimit  Int        @default(3)
  publishedAt   DateTime?
  status        QuizStatus  @default(PENDING)
  reviewedBy    String?
  reviewComment String?
  reviewedAt    DateTime?
  aiPrompt      String?
  timestamp     Int?       // Video timestamp in seconds where this quiz appears
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  quizAttempts  QuizAttempt[]
}

model QuizAttempt {
  id          String   @id @default(cuid())
  studentId   String
  quizId      String
  score       Float
  responseTime Int
  attemptNumber Int    @default(1)
  selectedAnswers Json?
  passed      Boolean  @default(false)
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  quiz        QuizQuestion @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model StudentProgress {
  id                 String   @id @default(cuid())
  studentId          String   @unique
  guardianName       String?
  currentCourseId    String?
  currentLectureId   String?
  avgScore           Float    @default(0)
  weakTopics         Json?
  streakDays         Int      @default(0)
  lastActivityAt     DateTime?
  completedCheckpoints Int    @default(0)
  lockedCheckpoints  Int      @default(0)
  progressPercentage Float    @default(0)
  completedLectures  Int      @default(0)
  failedQuizzes      Int      @default(0)
  updatedAt          DateTime @updatedAt
}
