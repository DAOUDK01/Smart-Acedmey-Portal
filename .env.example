# Example environment variables (do NOT commit real secrets)
# Copy this file to `.env` or set these in your deployment environment.

# PostgreSQL connection used by Prisma and the API
DATABASE_URL=postgresql://postgres:postgres123@localhost:5000/lms_db?schema=public

# API key-based quiz provider (preferred)
QUIZ_API_KEY=your_quiz_provider_api_key_here
# Optional: custom provider URL (defaults to a built-in example URL)
QUIZ_API_URL=https://api.example.com/generate

# Existing Ollama variables (if you still run Ollama locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
